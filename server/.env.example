# ──────────────────────────────────────
# Atopsy Server Environment Variables
# ──────────────────────────────────────

NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/atopsy?schema=public

# JWT
JWT_ACCESS_SECRET=change-this-to-a-very-long-random-string-at-least-64-chars
JWT_REFRESH_SECRET=change-this-to-another-very-long-random-string-at-least-64-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# FastAPI AI Service
FASTAPI_URL=http://127.0.0.1:8001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Account Security
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME_MINUTES=30
